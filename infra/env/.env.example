# SentinelAI — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Gemini API Keys ─────────────────────────────
# Blue Team (defensive) — used by Mechanic + Triage + Hunter agents
GEMINI_API_KEY_BLUE=your-blue-team-api-key-here

# Red Team (offensive) — used by Hacker agent
GEMINI_API_KEY_RED=your-red-team-api-key-here

# ─── Service URLs ─────────────────────────────────
ARENA_URL=http://localhost:8080
HOST=0.0.0.0
PORT=8000
